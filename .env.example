# ─── Solcast Solar Forecast ───────────────────────────────────────────────────
# Register at https://toolkit.solcast.com.au to get API access.
# Free hobbyist accounts include up to 10 API calls/day per rooftop site.

# Your Solcast API key — found in the Toolkit under Account → API Key.
SOLCAST_API_KEY=your_solcast_api_key_here

# The rooftop site resource ID for your installation.
# Create a rooftop site in the Toolkit (https://toolkit.solcast.com.au/rooftop-sites)
# and copy the Resource ID shown in the site's detail view.
SOLCAST_RESOURCE_ID=your_solcast_resource_id_here

# ─── GivEnergy Battery Inverter ───────────────────────────────────────────────
# Obtain API access at https://givenergy.cloud — navigate to Account → API tokens.

# Your GivEnergy Cloud API key.
GIVENERGY_API_KEY=your_givenergy_api_key_here

# The inverter serial number shown on the inverter label and in the GivEnergy portal.
GIVENERGY_INVERTER_SERIAL=your_inverter_serial_here

# ─── Morning Email Notifications ──────────────────────────────────────────────
# When AVEUM_NOTIFY_EMAIL is set, Aveum sends a daily savings summary email
# after each successful optimisation run.

# Recipient address for the morning energy report.
AVEUM_NOTIFY_EMAIL=your@email.com

# SMTP server credentials.
# Works with any SMTP provider — Gmail, Mailgun, Postmark, Amazon SES, etc.
AVEUM_SMTP_HOST=smtp.example.com
AVEUM_SMTP_PORT=587
AVEUM_SMTP_USER=your_smtp_username
AVEUM_SMTP_PASS=your_smtp_password

# Optional: override the From address (defaults to AVEUM_SMTP_USER).
# AVEUM_FROM_EMAIL=aveum@yourdomain.com
