# ─── Ohme EV Charger ──────────────────────────────────────────────────────────
# Ohme does not publish a public API. These credentials are used to authenticate
# against their unofficial mobile API (api.ohme.io). This integration may break
# if Ohme changes their backend — check the adapter comments for details.

# The email address you use to log in to the Ohme app.
OHME_EMAIL=your_ohme_email_here

# The password for your Ohme account.
OHME_PASSWORD=your_ohme_password_here

# ─── Zappi EV Charger (myenergi) ─────────────────────────────────────────────
# Create an API key in the myenergi app under Account.

# Your myenergi hub serial number.
ZAPPI_HUB_SERIAL=your_myenergi_hub_serial_here

# Your myenergi API key.
ZAPPI_API_KEY=your_myenergi_api_key_here

# Your Zappi charger serial number.
ZAPPI_SERIAL=your_zappi_serial_here

# Your Libbi home battery serial number (shares ZAPPI_HUB_SERIAL and ZAPPI_API_KEY above).
LIBBI_SERIAL=your_libbi_serial_here

# ─── EcoFlow Home Battery ─────────────────────────────────────────────────────
# Generate OpenAPI credentials from your EcoFlow developer account.

# EcoFlow OpenAPI access key.
ECOFLOW_ACCESS_KEY=your_ecoflow_access_key_here

# EcoFlow OpenAPI secret key.
ECOFLOW_SECRET_KEY=your_ecoflow_secret_key_here

# EcoFlow device serial number.
ECOFLOW_DEVICE_SN=your_ecoflow_device_sn_here

# ─── SolarEdge Inverter ─────────────────────────────────────────────────────
# Generate your API key in the SolarEdge monitoring portal.

# SolarEdge monitoring API key.
SOLAREDGE_API_KEY=your_solaredge_api_key_here

# SolarEdge site ID from the monitoring portal.
SOLAREDGE_SITE_ID=your_solaredge_site_id_here

# ─── Huawei FusionSolar Inverter ────────────────────────────────────────────
# Create credentials in FusionSolar OpenAPI and provide your station code.

# FusionSolar API username.
HUAWEI_USERNAME=your_huawei_username_here

# FusionSolar system code / API credential.
HUAWEI_SYSTEM_CODE=your_huawei_system_code_here

# FusionSolar station code.
HUAWEI_STATION_CODE=your_huawei_station_code_here

# ─── Solis Inverter ─────────────────────────────────────────────────────────
# Create API credentials in SolisCloud and capture your inverter ID.

# Solis Cloud key ID.
SOLIS_KEY_ID=your_solis_key_id_here

# Solis Cloud key secret.
SOLIS_KEY_SECRET=your_solis_key_secret_here

# Solis inverter ID.
SOLIS_INVERTER_ID=your_solis_inverter_id_here

# ─── Fox ESS Inverter ───────────────────────────────────────────────────────
# Generate an API key in Fox ESS Cloud and copy your device serial number.

# Fox ESS API key.
FOXESS_API_KEY=your_foxess_api_key_here

# Fox ESS device serial number.
FOXESS_DEVICE_SN=your_foxess_device_sn_here

# ─── Hypervolt EV Charger ───────────────────────────────────────────────────
HYPERVOLT_EMAIL=your_hypervolt_email_here
HYPERVOLT_PASSWORD=your_hypervolt_password_here
HYPERVOLT_CHARGER_ID=your_hypervolt_charger_id_here

# ─── Wallbox EV Charger ─────────────────────────────────────────────────────
WALLBOX_EMAIL=your_wallbox_email_here
WALLBOX_PASSWORD=your_wallbox_password_here
WALLBOX_CHARGER_ID=your_wallbox_charger_id_here

# ─── Easee EV Charger ───────────────────────────────────────────────────────
EASEE_EMAIL=your_easee_email_here
EASEE_PASSWORD=your_easee_password_here
EASEE_CHARGER_ID=your_easee_charger_id_here

# ─── Pod Point EV Charger ───────────────────────────────────────────────────
PODPOINT_EMAIL=your_podpoint_email_here
PODPOINT_PASSWORD=your_podpoint_password_here
PODPOINT_UNIT_ID=your_podpoint_unit_id_here

# ─── Indra EV Charger ───────────────────────────────────────────────────────
INDRA_EMAIL=your_indra_email_here
INDRA_PASSWORD=your_indra_password_here
INDRA_DEVICE_ID=your_indra_device_id_here

# ─── tado Smart Thermostat ───────────────────────────────────────────────────
# tado uses a standard OAuth2 password flow to authenticate. These are your
# tado account credentials — the same ones you use to log in to the tado app.
# The adapter exchanges them for a short-lived bearer token automatically.

# The email address you use to log in to the tado app.
TADO_USERNAME=your_tado_email_here

# The password for your tado account.
TADO_PASSWORD=your_tado_password_here

# ─── Upstash Redis (user registration store) ──────────────────────────────────
# Create a free Redis database at https://upstash.com, then copy the REST URL
# and token from the database's "REST API" section.
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# ─── Solcast Solar Forecast ───────────────────────────────────────────────────
# Register at https://toolkit.solcast.com.au to get API access.
# Free hobbyist accounts include up to 10 API calls/day per rooftop site.

# Your Solcast API key — found in the Toolkit under Account → API Key.
SOLCAST_API_KEY=your_solcast_api_key_here

# The rooftop site resource ID for your installation.
# Create a rooftop site in the Toolkit (https://toolkit.solcast.com.au/rooftop-sites)
# and copy the Resource ID shown in the site's detail view.
SOLCAST_RESOURCE_ID=your_solcast_resource_id_here

# ─── GivEnergy Battery Inverter ───────────────────────────────────────────────
# Obtain API access at https://givenergy.cloud — navigate to Account → API tokens.

# Your GivEnergy Cloud API key.
GIVENERGY_API_KEY=your_givenergy_api_key_here

# The inverter serial number shown on the inverter label and in the GivEnergy portal.
GIVENERGY_INVERTER_SERIAL=your_inverter_serial_here

# ─── Morning Email Notifications ──────────────────────────────────────────────
# When AVEUM_NOTIFY_EMAIL is set, Aveum sends a daily savings summary email
# after each successful optimisation run.

# Recipient address for the morning energy report.
AVEUM_NOTIFY_EMAIL=your@email.com

# SMTP server credentials.
# Works with any SMTP provider — Gmail, Mailgun, Postmark, Amazon SES, etc.
AVEUM_SMTP_HOST=smtp.example.com
AVEUM_SMTP_PORT=587
AVEUM_SMTP_USER=your_smtp_username
AVEUM_SMTP_PASS=your_smtp_password

# Optional: override the From address (defaults to AVEUM_SMTP_USER).
# AVEUM_FROM_EMAIL=aveum@yourdomain.com

# ─── Notion Analytics ─────────────────────────────────────────────────────────
# After each daily cron run, Aveum logs per-user results to a Notion database.
# Create an Internal Integration at https://www.notion.so/my-integrations,
# then share the target database with the integration via ••• → Connections.

# Your Notion Internal Integration secret (starts with secret_).
NOTION_API_KEY=your_notion_api_key_here

# The ID of the Notion database that receives daily run results.
# Copy it from the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_RESULTS_DATABASE_ID=your_notion_database_id_here
